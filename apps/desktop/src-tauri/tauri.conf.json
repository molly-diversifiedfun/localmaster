{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalMaster",
  "version": "0.1.0",
  "identifier": "com.localmaster.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalMaster",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Library/Caches/LocalMaster/**", "$HOME/**", "/Volumes/**"]
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/localmaster-engine"]
  }
}
