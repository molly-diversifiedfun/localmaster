{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalMaster",
  "version": "0.1.0",
  "identifier": "com.localmaster.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalMaster",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Library/Caches/LocalMaster/**", "$HOME/**", "/Volumes/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/localmaster-engine"],
    "macOS": {
      "signingIdentity": null
    }
  }
}
